# ============================================================
# ChildLink-MA Assistant — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env
# ============================================================

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4.1-mini
OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
EMBEDDING_DIM=1536

# FAISS index paths (inside Docker container)
FAISS_INDEX_PATH=/app/clm_index_v3.index
FAISS_METADATA_PATH=/app/clm_metadata_v3.json

# CORS — comma-separated allowed origins
FRONTEND_ORIGINS=https://childlink-ma.org,https://www.childlink-ma.org

# Rate limiting (requests per day per hashed IP)
DAILY_ASK_LIMIT=3

# Optional public API key for external callers
PUBLIC_API_KEY=

# Make.com webhook (feedback → Google Sheets)
MAKE_WEBHOOK_URL=
MAKE_WEBHOOK_KEY=
MAKE_WEBHOOK_HEADER=x-make-apikey

# Port (Azure App Service sets this automatically)
PORT=8000
